# Backend Environment Variables
# Copy this file to .env and fill in your values

# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/student_dashboard"

# ─── JWT Secrets ─────────────────────────────────────────────────────────────
# Generate strong secrets with: openssl rand -hex 64
JWT_ACCESS_SECRET="REPLACE_WITH_STRONG_64_CHAR_SECRET_FOR_ACCESS_TOKENS"
JWT_REFRESH_SECRET="REPLACE_WITH_STRONG_64_CHAR_SECRET_FOR_REFRESH_TOKENS"

# Token expiry times (use ms, s, m, h, d notation)
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server Config ────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV="development"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# ─── Redis (for rate limiting / caching) ────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Cookie Settings ──────────────────────────────────────────────────────────
# Must be "true" in production (requires HTTPS)
COOKIE_SECURE="false"
COOKIE_SAME_SITE="lax"

# ─── Attendance Anomaly Settings ─────────────────────────────────────────────
# Students with attendance below this percentage get flagged
ATTENDANCE_THRESHOLD=75

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL="debug"

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
